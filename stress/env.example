# Copy to stress/.env

# MUST be localhost or 127.0.0.1 — guard-env.sh fails otherwise.
STRESS_SUPABASE_URL=http://127.0.0.1:54321
STRESS_SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Anon key from `supabase status`. NOT a secret in local dev.
STRESS_SUPABASE_ANON_KEY=

# Service role key from `supabase status`. Used only by seed/cron scripts,
# never by k6 or concurrency tests.
STRESS_SUPABASE_SERVICE_ROLE_KEY=

# Auth mode: "login" (default, robust) or "mint" (fast, requires GOTRUE_JWT_SECRET).
STRESS_AUTH_MODE=login

# Only read when STRESS_AUTH_MODE=mint. Source: `supabase status --output env`.
# Leave blank in login mode.
GOTRUE_JWT_SECRET=

# Password used for all seed users in login mode. Local-only.
STRESS_SEED_PASSWORD=stress-test-pw-local-only

# Smoke vs full seed
STRESS_SEED_MODE=smoke
