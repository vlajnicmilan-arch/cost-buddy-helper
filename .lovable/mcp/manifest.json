      {
        "name": "create_expense",
        "title": "Create expense",
        "description": "Insert a new expense (troška) for the signed-in user in V&M Balance. Amount is a positive number in the given currency. Date is ISO (YYYY-MM-DD). Category is a free-form string.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "amount": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "Positive amount (e.g. 12.50)"
            },
            "currency": {
              "type": "string",
              "description": "ISO 4217 currency code, e.g. 'EUR'. Defaults to 'EUR'."
            },
            "date": {
              "type": "string",
              "description": "ISO date YYYY-MM-DD. Defaults to today if omitted."
            },
            "category": {
              "type": "string",
              "description": "Category name, e.g. 'groceries'."
            },
            "description": {
              "type": "string",
              "description": "Short description / merchant note."
            },
            "payment_source": {
              "type": "string",
              "description": "Payment source id. Either a system id like 'cash' or 'custom:<uuid>' for a user wallet. Defaults to 'cash'."
            }
          },
          "required": [
            "amount",
            "currency",
            "date",
            "category",
            "description",
            "payment_source"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_budgets",
